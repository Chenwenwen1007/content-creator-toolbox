APP_NAME=short-video-parser
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001
APP_BASE_URL=http://127.0.0.1:8001
CORS_ORIGINS=*
HTTP_TIMEOUT=20
DOWNLOAD_TIMEOUT=120
LOG_LEVEL=INFO

