[Unit]
Description=Personal Short Video Parser
After=network.target

[Service]
User=root
WorkingDirectory=/opt/qushuiyin
EnvironmentFile=/opt/qushuiyin/.env
ExecStart=/opt/qushuiyin/venv/bin/gunicorn server.app:app -k uvicorn.workers.UvicornWorker -w 2 -b 127.0.0.1:8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
